{
  "info": {
    "name": "JanVaani AI Backend APIs",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Citizen",
      "item": [
        {
          "name": "Register Citizen",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone_number\": \"9876543210\",\n  \"name\": \"Rahul Sharma\",\n  \"constituency\": \"New Delhi\",\n  \"language_preference\": \"Hindi\"\n}"
            },
            "url": {
              "raw": "http://127.0.0.1:8000/api/v1/citizens/register",
              "protocol": "http",
              "host": ["127", "0", "0", "1"],
              "port": "8000",
              "path": ["api", "v1", "citizens", "register"]
            }
          }
        },
        {
          "name": "Login Citizen",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone_number\": \"9876543210\"\n}"
            },
            "url": {
              "raw": "http://127.0.0.1:8000/api/v1/citizens/login",
              "protocol": "http",
              "host": ["127", "0", "0", "1"],
              "port": "8000",
              "path": ["api", "v1", "citizens", "login"]
            }
          }
        },
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{citizen_token}}" }
            ],
            "url": {
              "raw": "http://127.0.0.1:8000/api/v1/citizens/profile",
              "protocol": "http",
              "host": ["127", "0", "0", "1"],
              "port": "8000",
              "path": ["api", "v1", "citizens", "profile"]
            }
          }
        }
      ]
    },
    {
      "name": "2. Complaints",
      "item": [
        {
          "name": "Submit Complaint",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{citizen_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Broken Streetlight\",\n  \"description\": \"Streetlight on MG road is flickering.\",\n  \"department_id\": 1,\n  \"location_lat\": 28.6139,\n  \"location_lng\": 77.2090,\n  \"address\": \"MG Road\"\n}"
            },
            "url": {
              "raw": "http://127.0.0.1:8000/api/v1/complaints/",
              "protocol": "http",
              "host": ["127", "0", "0", "1"],
              "port": "8000",
              "path": ["api", "v1", "complaints", ""]
            }
          }
        },
        {
          "name": "Get Tracking",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://127.0.0.1:8000/api/v1/complaints/1/tracking",
              "protocol": "http",
              "host": ["127", "0", "0", "1"],
              "port": "8000",
              "path": ["api", "v1", "complaints", "1", "tracking"]
            }
          }
        }
      ]
    },
